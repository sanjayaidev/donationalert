# Payment Gateway Credentials
# Cashfree - Production credentials (use these for live payments)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# Cashfree - Sandbox credentials (optional, for testing)
# If not provided, production credentials will be used in all environments
CASHFREE_SANDBOX_APP_ID=your_sandbox_app_id
CASHFREE_SANDBOX_SECRET_KEY=your_sandbox_secret_key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# StreamElements Configuration
SE_CHANNEL_ID=your_se_channel_id
SE_JWT_TOKEN=your_se_jwt_token

# Stream Configuration
DEFAULT_YOUTUBE_URL=https://www.youtube.com/watch?v=YOUR_VIDEO_ID
SE_CHAT_URL=https://streamelements.com/dashboard/chatbot/overlay/YOUR_CHANNEL

# Webhook & Logging
WEBHOOK_URL=https://your-domain.com/api/webhook
SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1
LOG_SECRET=your_log_secret
TEST_PASSWORD=your_test_password
